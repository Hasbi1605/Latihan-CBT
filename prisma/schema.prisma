// Skema database Simulasi CBT UIN Siber Cirebon
// Referensi model data: docs/PRD-Simulasi-CBT-UIN-Siber-Cirebon.md (bagian 8)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  PESERTA
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  nama         String
  nomorPeserta String    @unique
  passwordHash String
  role         Role      @default(PESERTA)
  createdAt    DateTime  @default(now())
  attempts     Attempt[]
}

model Subtest {
  id        String   @id @default(cuid())
  kode      String   @unique // TPA, BAHASA, KEISLAMAN
  nama      String
  deskripsi String?
  urutan    Int      @default(0)

  questions       Question[]
  packageSections ExamPackageSection[]
  attemptSections AttemptSection[]
}

model Question {
  id             String   @id @default(cuid())
  subtestId      String
  subtest        Subtest  @relation(fields: [subtestId], references: [id], onDelete: Cascade)
  subkategori    String?
  teks           String
  tipe           String   @default("PG") // PG | REKAMAN
  arahTeks       String   @default("LTR")
  gambarUrl      String?
  audioPromptUrl String?
  pembahasan     String?
  tingkat        String   @default("SEDANG")
  createdAt      DateTime @default(now())

  options    Option[]
  answers    AttemptAnswer[]
  recordings AttemptRecording[]
}

model Option {
  id         String  @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String // A, B, C, D, E
  teks       String
  isCorrect  Boolean @default(false)
}

model ExamPackage {
  id        String   @id @default(cuid())
  nama      String
  mode      String   @default("REPLIKA_2026") // REPLIKA_2026 atau LATIHAN_LENGKAP
  token     String
  deskripsi String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())

  sections ExamPackageSection[]
  attempts Attempt[]
}

model ExamPackageSection {
  id          String  @id @default(cuid())
  packageId   String
  package     ExamPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  subtestId   String
  subtest     Subtest @relation(fields: [subtestId], references: [id])
  urutan      Int
  jumlahSoal  Int
  durasiDetik Int
  acakSoal    Boolean @default(true)
  acakOpsi    Boolean @default(true)
}

model Attempt {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId      String
  package        ExamPackage @relation(fields: [packageId], references: [id])
  status         String    @default("BERLANGSUNG")
  mulaiAt        DateTime  @default(now())
  selesaiAt      DateTime?
  skorTotal      Float?
  tabSwitchCount Int       @default(0)
  createdAt      DateTime  @default(now())

  sections AttemptSection[]
}

model AttemptSection {
  id          String    @id @default(cuid())
  attemptId   String
  attempt     Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  subtestId   String
  subtest     Subtest   @relation(fields: [subtestId], references: [id])
  urutan      Int
  durasiDetik Int
  mulaiAt     DateTime? // waktu peserta memulai subtes ini (dasar timer server)
  selesaiAt   DateTime?
  status      String    @default("BELUM") // BELUM, BERLANGSUNG, SELESAI
  benar       Int?
  salah       Int?
  kosong      Int?
  skor        Float?

  answers    AttemptAnswer[]
  recordings AttemptRecording[]
}

model AttemptRecording {
  id               String   @id @default(cuid())
  attemptSectionId String
  attemptSection   AttemptSection @relation(fields: [attemptSectionId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question @relation(fields: [questionId], references: [id])
  answerId         String?  @unique
  audioUrl         String?
  nilaiManual      Float?
  rubrikKelancaran Int?
  rubrikTajwid     Int?
  rubrikMakhraj    Int?
  catatanPenguji   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([attemptSectionId, questionId])
}

model AttemptAnswer {
  id               String   @id @default(cuid())
  attemptSectionId String
  attemptSection   AttemptSection @relation(fields: [attemptSectionId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question @relation(fields: [questionId], references: [id])
  urutan           Int
  optionOrderJson  String // urutan tampil opsi (array id opsi) untuk acak opsi
  pilihanOptionId  String? // id opsi yang dipilih peserta
  ragu             Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@unique([attemptSectionId, questionId])
}
