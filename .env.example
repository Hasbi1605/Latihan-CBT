# Salin file ini menjadi .env lalu sesuaikan bila perlu.

# Kunci untuk menandatangani sesi (JWT). WAJIB diganti di produksi.
# Jika tidak diisi, akan memakai nilai default pengembangan.
AUTH_SECRET="ganti-dengan-string-acak-yang-panjang"

# Catatan: URL database SQLite.
# Dev lokal: file:./dev.db (default di bawah)
DATABASE_URL="file:./dev.db"
